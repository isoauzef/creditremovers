// Credit Removers — Prisma schema
// MySQL via DATABASE_URL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ── Admin user (email + password login) ─────────────────────────────
model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique @db.VarChar(255)
  passwordHash String   @db.VarChar(255)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs    PiiAuditLog[]

  @@map("admin_users")
}

// ── Customer (paying client) — created post-checkout ────────────────
model CustomerUser {
  id              Int       @id @default(autoincrement())
  email           String    @unique @db.VarChar(255)
  passwordHash    String    @db.VarChar(255)
  firstName       String    @db.VarChar(128)
  lastName        String    @db.VarChar(128)
  resetToken      String?   @db.VarChar(128)
  resetExpiresAt  DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  checkoutSubmissions CheckoutSubmission[]
  creditRounds        CreditReportRound[]

  @@map("customer_users")
}

// ── Lead-gen contact form (homepage) ────────────────────────────────
model ContactSubmission {
  id                 Int      @id @default(autoincrement())
  firstName          String   @db.VarChar(128)
  lastName           String   @db.VarChar(128)
  email              String   @db.VarChar(255)
  phone              String   @db.VarChar(50)
  state              String?  @db.VarChar(64)
  creditScoreRange   String?  @db.VarChar(32)  // <500 | 500-579 | 580-669 | 670-739 | 740+ | unknown
  negativeItemsCount String?  @db.VarChar(32)  // 1-3 | 4-7 | 8-15 | 16+ | unknown
  notes              String?  @db.Text
  source             String?  @db.VarChar(64)
  metadata           Json?
  createdAt          DateTime @default(now())

  @@map("contact_submissions")
}

// ── Checkout / signed-up client submissions ─────────────────────────
model CheckoutSubmission {
  id                          Int       @id @default(autoincrement())
  customerUserId              Int?
  customerUser                CustomerUser? @relation(fields: [customerUserId], references: [id], onDelete: SetNull)

  // Public contact info
  firstName                   String    @db.VarChar(128)
  lastName                    String    @db.VarChar(128)
  email                       String    @db.VarChar(255)
  phone                       String    @db.VarChar(50)
  addressLine1                String    @db.VarChar(255)
  addressLine2                String?   @db.VarChar(255)
  city                        String    @db.VarChar(128)
  state                       String    @db.VarChar(64)
  zip                         String    @db.VarChar(16)
  dateOfBirth                 DateTime  @db.Date

  // Encrypted PII (KMS envelope encryption)
  ssnCiphertext               Bytes?
  ssnEncryptedDek             Bytes?
  ssnIv                       Bytes?
  ssnAuthTag                  Bytes?
  ssnLast4                    String?   @db.VarChar(4)

  // S3 keys (objects encrypted at rest with SSE-KMS)
  idDocS3Key                  String?   @db.VarChar(512)
  idDocFilename               String?   @db.VarChar(255)
  idDocMimeType               String?   @db.VarChar(64)
  billDocS3Key                String?   @db.VarChar(512)
  billDocFilename             String?   @db.VarChar(255)
  billDocMimeType             String?   @db.VarChar(64)

  // Authorization & signature
  signatureName               String?   @db.VarChar(255)
  signatureDataUrl            String?   @db.LongText  // base64 SVG/PNG of canvas signature
  signatureDate               DateTime?
  signatureIpHash             String?   @db.VarChar(128)
  authConsent                 Boolean   @default(false)

  // Stripe
  paymentPlan                 String    @db.VarChar(16) // monthly | upfront
  stripeCustomerId            String?   @db.VarChar(255)
  stripeSubscriptionId        String?   @db.VarChar(255)
  stripeSubscriptionScheduleId String?  @db.VarChar(255)
  stripePaymentIntentId       String?   @db.VarChar(255)
  stripePaymentMethodId       String?   @db.VarChar(255)
  paymentStatus               String    @default("pending") @db.VarChar(32) // pending | active | paid | completed | canceled | failed
  monthsBilled                Int       @default(0)
  totalPaidCents              Int       @default(0)

  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  auditLogs                   PiiAuditLog[]

  @@index([customerUserId])
  @@index([email])
  @@map("checkout_submissions")
}

// ── PII access audit log ────────────────────────────────────────────
model PiiAuditLog {
  id                    Int       @id @default(autoincrement())
  adminUserId           Int
  adminUser             AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  checkoutSubmissionId  Int
  checkoutSubmission    CheckoutSubmission @relation(fields: [checkoutSubmissionId], references: [id], onDelete: Cascade)
  field                 String    @db.VarChar(32)  // ssn | idDoc | billDoc
  action                String    @db.VarChar(32)  // view | decrypt | download
  ip                    String?   @db.VarChar(64)
  userAgent             String?   @db.VarChar(512)
  createdAt             DateTime  @default(now())

  @@index([checkoutSubmissionId])
  @@index([adminUserId])
  @@map("pii_audit_logs")
}

// ── Credit dispute round (drives customer dashboard) ────────────────
model CreditReportRound {
  id                              Int      @id @default(autoincrement())
  customerUserId                  Int
  customerUser                    CustomerUser @relation(fields: [customerUserId], references: [id], onDelete: Cascade)
  roundNumber                     Int
  summaryDate                     DateTime @db.Date
  previousSummaryDate             DateTime? @db.Date

  // Bureau scores
  equifaxScore                    Int
  equifaxPrevScore                Int
  experianScore                   Int
  experianPrevScore               Int
  transunionScore                 Int
  transunionPrevScore             Int

  // Disputes Deleted
  disputesDeletedThisRound        Int      @default(0)
  disputesDeletedLastRound        Int      @default(0)
  disputesDeletedGrandTotal       Int      @default(0)

  // Disputes On-Going
  disputesOnGoingThisRound        Int      @default(0)
  disputesOnGoingLastRound        Int      @default(0)
  disputesOnGoingGrandTotal       Int      @default(0)

  // Un-Disputed Negative
  unDisputedNegativeThisRound     Int      @default(0)
  unDisputedNegativeLastRound     Int      @default(0)
  unDisputedNegativeGrandTotal    Int      @default(0)

  // Updated to Positive
  updatedToPositiveThisRound      Int      @default(0)
  updatedToPositiveLastRound      Int      @default(0)
  updatedToPositiveGrandTotal     Int      @default(0)

  // New Items Added
  newItemsAddedThisRound          Int      @default(0)
  newItemsAddedLastRound          Int      @default(0)
  newItemsAddedGrandTotal         Int      @default(0)

  notes                           String?  @db.Text
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt

  @@unique([customerUserId, roundNumber])
  @@index([customerUserId])
  @@map("credit_report_rounds")
}

// ── News / blog articles ────────────────────────────────────────────
model NewsArticle {
  id             Int       @id @default(autoincrement())
  slug           String    @unique @db.VarChar(255)
  title          String    @db.VarChar(255)
  excerpt        String    @db.Text
  content        String    @db.LongText
  coverImageUrl  String?   @db.VarChar(512)
  author         String?   @db.VarChar(128)
  published      Boolean   @default(false)
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([published, publishedAt])
  @@map("news_articles")
}

// ── Email templates ─────────────────────────────────────────────────
model EmailTemplate {
  id          Int      @id @default(autoincrement())
  slug        String   @unique @db.VarChar(64)
  name        String   @db.VarChar(128)
  subject     String   @db.VarChar(500)
  previewText String?  @db.VarChar(500)
  content     Json
  enabled     Boolean  @default(true)
  updatedAt   DateTime @updatedAt

  @@map("email_templates")
}

// ── Key-value settings ──────────────────────────────────────────────
model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(128)
  value     String   @db.Text
  group     String   @db.VarChar(32) // stripe | smtp | site | email | aws | security
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ── CMS page content ────────────────────────────────────────────────
model PageContent {
  id        Int      @id @default(autoincrement())
  page      String   @db.VarChar(64)
  section   String   @db.VarChar(64)
  content   Json
  updatedAt DateTime @updatedAt

  @@unique([page, section])
  @@map("page_content")
}
