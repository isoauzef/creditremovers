# Core app runtime
NODE_ENV=production
API_PORT=4174
PUBLIC_ORIGIN=https://creditremovers.com
DATABASE_URL="mysql://creditremovers:change-me@localhost:3306/creditremovers"
JWT_SECRET=replace-with-strong-admin-jwt-secret
CUSTOMER_JWT_SECRET=replace-with-strong-customer-jwt-secret

# Seeded on first bootstrap only
SEED_ADMIN_EMAIL=admin@creditremovers.com
SEED_ADMIN_PASSWORD=replace-with-strong-admin-password
SITE_NAME=Credit Removers
SITE_URL=https://creditremovers.com
SITE_SUPPORT_EMAIL=support@creditremovers.com
SITE_SUPPORT_PHONE=+1 (888) 000-0000

# Stripe defaults seeded into the settings table on first bootstrap
STRIPE_MODE=live
STRIPE_TEST_PUBLISHABLE_KEY=
STRIPE_TEST_SECRET_KEY=
STRIPE_TEST_WEBHOOK_SECRET=
STRIPE_LIVE_PUBLISHABLE_KEY=
STRIPE_LIVE_SECRET_KEY=
STRIPE_LIVE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_MONTHLY_AMOUNT_CENTS=40000
STRIPE_MONTHLY_MONTHS=3
STRIPE_UPFRONT_AMOUNT_CENTS=100000
STRIPE_UPFRONT_SAVINGS_LABEL=Save $200

# SMTP defaults seeded into the settings table on first bootstrap
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Credit Removers <support@creditremovers.com>"
SMTP_REPLY_TO=support@creditremovers.com

# AWS runtime credentials used directly by the server
AWS_REGION=us-east-1
AWS_KMS_KEY_ID=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Local encryption fallback only; leave empty when using AWS KMS
ENCRYPTION_KEY=
